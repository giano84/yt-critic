{
  "manifest_version": 3,
  "name": "YT Critic — Critical analysis with fact-checking",
  "version": "2.0.0",
  "description": "Get a critical analysis and fact-check of any YouTube video in one click.",
  "permissions": ["activeTab", "storage", "windows", "tabs", "scripting"],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://web-production-9c48.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://*.youtube.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "web_accessible_resources": [{
    "resources": ["analysis.html", "analysis.js"],
    "matches": ["chrome-extension://*/*"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

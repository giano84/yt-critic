{
  "manifest_version": 3,
  "name": "YT Critic — AI Fact-Checker for YouTube",
  "version": "2.2.0",
  "description": "Fact-check any YouTube video in 60 seconds. Claude AI analyzes the transcript and verifies claims with OSINT sources.",
  "permissions": ["activeTab", "storage", "windows", "scripting"],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://web-production-9c48.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://*.youtube.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
